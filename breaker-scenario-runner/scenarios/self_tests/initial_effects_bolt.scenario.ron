// Smoke test: initial_effects bolt targeting via PendingBoltEffects.
// SpeedBoost(1.1) is applied to the bolt on each Bumped event.
// BoltSpeedAccurate verifies the speed remains within configured bounds despite
// the boost, confirming the effect dispatches without corrupting bolt state.
(
    breaker: "godmode",
    layout: "quick_clear",
    input: Perfect(AlwaysPerfect),
    max_frames: 1000,
    disallowed_failures: [BoltInBounds, BreakerInBounds, NoNaN, BoltSpeedAccurate],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 42,
    initial_effects: [
        Stamp(Bolt, When(Bumped, Fire(SpeedBoost((multiplier: 1.1))))),
    ],
)
