// Smoke test: Perfect(AlwaysPerfect) input strategy.
// Every bump is perfectly timed. Aegis + Corridor provides cells to hit and
// enough play time for multiple bump cycles. Verifies no crash and invariants
// hold across sustained perfect-bump play.
(
    breaker: "godmode",
    layout: "Corridor",
    input: Perfect(AlwaysPerfect),
    max_frames: 5000,
    disallowed_failures: [BoltInBounds, BreakerInBounds, NoNaN, BoltSpeedAccurate],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 42,
)
