// Smoke test: Perfect(AlwaysPerfect) input strategy.
// Every bump is perfectly timed. Godmode + quick_clear sustains play past bolt_lost.
// Verifies no crash and invariants hold across many perfect-bump cycles.
(
    breaker: "godmode",
    layout: "quick_clear",
    input: Perfect(AlwaysPerfect),
    max_frames: 1000,
    disallowed_failures: [BoltInBounds, BreakerInBounds, NoNaN, ValidStateTransitions, BoltSpeedAccurate],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 42,
)
