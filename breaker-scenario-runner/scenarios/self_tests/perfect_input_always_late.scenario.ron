// Verifies Perfect(AlwaysLate) runs without crash. Every bump is graded Late.
// Godmode + quick_clear sustains play across many late-bump cycles.
(
    breaker: "godmode",
    layout: "quick_clear",
    input: Perfect(AlwaysLate),
    max_frames: 1000,
    invariants: [BoltInBounds, BreakerInBounds, NoNaN, ValidStateTransitions, BoltSpeedInRange],
    expected_violations: None,
    debug_setup: None,
    allow_early_end: false,
    seed: Some(42),
)
