// Verifies Perfect(AlwaysLate) runs without crash. Every bump is graded Late.
// Aegis + Corridor provides cells to hit across many late-bump cycles.
(
    breaker: "godmode",
    layout: "Corridor",
    input: Perfect(AlwaysLate),
    max_frames: 5000,
    disallowed_failures: [BoltInBounds, BreakerInBounds, NoNaN, BoltSpeedAccurate],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 42,
)
