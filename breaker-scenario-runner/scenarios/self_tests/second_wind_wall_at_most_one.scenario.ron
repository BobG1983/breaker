(
    breaker: "Aegis",
    layout: "Corridor",
    input: Scripted((
        actions: [],
    )),
    max_frames: 120,
    invariants: [SecondWindWallAtMostOne],
    expected_violations: Some([SecondWindWallAtMostOne]),
    debug_setup: (
