(
    breaker: "Aegis",
    layout: "Corridor",
    input: Scripted((
        actions: [],
    )),
    max_frames: 120,
    disallowed_failures: [ChainArcCountReasonable],
    allowed_failures: Some([ChainArcCountReasonable]),
    debug_setup: (
        disable_physics: true,
    ),
    // max_chain_arc_count default is 50.
    // Spawn 30 chain + 30 arc = 60 entities — 10 over the default threshold.
    frame_mutations: [
        (frame: 30, mutation: SpawnExtraChainArcs(30)),
    ],
)
