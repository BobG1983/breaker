// Smoke test: Perfect(Random) input strategy.
// Bump grade is randomly selected each frame from the full BumpMode set.
// Aegis + Corridor provides cells for sustained play across varied bump outcomes.
// Verifies no crash and speed invariants hold under random grade oscillation.
(
    breaker: "godmode",
    layout: "Corridor",
    input: Perfect(Random),
    max_frames: 3000,
    disallowed_failures: [BoltInBounds, BreakerInBounds, NoNaN, BoltSpeedAccurate],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 99,
)
