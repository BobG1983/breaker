(
    breaker: "Aegis",
    layout: "Corridor",
    input: Scripted((
        actions: [],
    )),
    max_frames: 120,
    invariants: [ShieldChargesConsistent],
    expected_violations: Some([ShieldChargesConsistent]),
    debug_setup: (
        disable_physics: true,
    ),
    allow_early_end: false,
    // At frame 30: spawn a ShieldActive { charges: 0 } entity.
    // This simulates a removal-system failure that leaves a dead shield alive.
    // The invariant fires immediately when charges == 0 is detected.
    frame_mutations: [
        (frame: 30, mutation: InjectZeroChargeShield),
    ],
)
