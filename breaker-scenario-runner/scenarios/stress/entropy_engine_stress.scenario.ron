// Guard: EntropyEngine fires up to 3 random effects per cell destruction.
// Pool contains SpawnBolts and Shockwave with equal weight — random selection means
// either effect fires each time. Dense layout drives rapid destructions. Guards
// against runaway bolt accumulation and entity leaks. Stress: 32 runs.
(
    breaker: "Aegis",
    layout: "Dense",
    input: Chaos((action_prob: 0.5)),
    max_frames: 4000,
    disallowed_failures: [BoltInBounds, BoltCountReasonable, BreakerCountReasonable, BreakerInBounds, NoEntityLeaks, NoNaN],
    allowed_failures: [],
    debug_setup: None,
    invariant_params: (max_bolt_count: 20),
    allow_early_end: false,
    seed: 4242,
    initial_effects: [
        Stamp(Bolt, When(DeathOccurred(Cell), Fire(EntropyEngine((max_effects: 3,
                    pool: [
                        (0.5, SpawnBolts((count: 1, lifespan: Some(2.0), inherit: false))),
                        (0.5, Shockwave((base_range: 32.0, range_per_level: 0.0, stacks: 1, speed: 400.0))),
                    ],))))),
    ],
)
