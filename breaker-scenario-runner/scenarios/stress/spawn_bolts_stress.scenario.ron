// Adversarial: Prism already spawns bolts on PerfectBump. Adding SpawnBolts on PerfectBumped
// (bolt-perspective) compounds bolt count accumulation. High action_prob drives rapid bumps.
// If bolt count escapes the cap or spawned bolts leak entities after their lifespan expires,
// BoltCountReasonable and NoEntityLeaks will fire. Tests lifespan timer cleanup under load.
// Stress: 16 runs to explore different spawn patterns.
(
    breaker: "Prism",
    layout: "Scatter",
    input: Chaos((action_prob: 0.8)),
    max_frames: 5000,
    invariants: [BoltCountReasonable, NoEntityLeaks, BoltInBounds, NoNaN],
    expected_violations: None,
    debug_setup: None,
    invariant_params: (max_bolt_count: 16),
    allow_early_end: false,
    stress: Some((runs: 16, parallelism: 16)),
    seed: Some(5050),
    initial_effects: Some([
        On(target: Bolt, then: [
            When(trigger: PerfectBumped, then: [
                Do(SpawnBolts(count: 1, lifespan: Some(3.0), inherit: true)),
            ]),
        ]),
    ]),
)
