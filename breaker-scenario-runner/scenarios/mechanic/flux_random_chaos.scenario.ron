// Adversarial: RandomEffect fires on every bump — 50% chance SpeedBoost, 50% chance
// Shockwave. The weighted random selection must always produce exactly one child effect.
// If RandomEffect fires both (weight bug) or neither (zero-weight fallthrough), BoltSpeedAccurate
// or NoEntityLeaks diverge from expected. Godmode breaker guarantees infinite play;
// Perfect(AlwaysPerfect) input maximises bump frequency across 5000 frames.
// Seeds vary across runs to hit different probability sequences.
(
    breaker: "godmode",
    layout: "Dense",
    input: Perfect(AlwaysPerfect),
    max_frames: 5000,
    disallowed_failures: [BoltInBounds, BoltSpeedAccurate, BreakerCountReasonable, BreakerInBounds, NoEntityLeaks, NoNaN],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 6174,
    initial_effects: [
        Stamp(Bolt, When(Bumped, Fire(RandomEffect((pool: [
                    (0.5, SpeedBoost((multiplier: 1.1))),
                    (0.5, Shockwave((base_range: 24.0, range_per_level: 0.0, stacks: 1, speed: 400.0))),
                ]))))),
    ],
)
