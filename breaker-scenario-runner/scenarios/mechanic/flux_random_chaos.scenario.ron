// Adversarial: RandomEffect fires on every bump — 50% chance SpeedBoost, 50% chance
// Shockwave. The weighted random selection must always produce exactly one child effect.
// If RandomEffect fires both (weight bug) or neither (zero-weight fallthrough), BoltSpeedInRange
// or NoEntityLeaks diverge from expected. High action_prob (0.7) maximises bump frequency
// across 5000 frames. Seeds vary across runs to hit different probability sequences.
(
    breaker: "Aegis",
    layout: "Dense",
    input: Chaos((
        seed: 6174,
        action_prob: 0.7,
    )),
    max_frames: 5000,
    invariants: [BoltInBounds, BoltSpeedInRange, NoEntityLeaks, NoNaN],
    expected_violations: None,
    debug_setup: None,
    allow_early_end: false,
    initial_overclocks: Some([
        When(trigger: OnBump, then: [
            Do(RandomEffect([
                (0.5, Do(SpeedBoost(multiplier: 1.1))),
                (0.5, Do(Shockwave(base_range: 24.0, range_per_level: 0.0, stacks: 1, speed: 400.0))),
            ])),
        ]),
    ]),
)
