// Adversarial: RampingDamage accumulates on every Impacted(Cell) trigger. Scatter layout
// produces irregular inter-cell distances — the bolt travels long gaps between hits, then
// clusters several impacts in quick succession. This exercises the monotonic accumulation
// path (trigger_count up, accumulated up) and the reverse() path when a node ends and the
// component is removed. Godmode breaker guarantees infinite play so the bolt persists long
// enough to accumulate thousands of cell hits. The adversarial risk: if accumulated ever
// produces NaN (e.g. from f32 overflow after thousands of hits), or if BoltInBounds breaks
// because a damage calculation corrupts bolt velocity, these invariants catch it.
// Perfect(AlwaysPerfect) input sustains active play so the bolt bounces long enough to hit
// every cell multiple times across 8000 frames.
(
    breaker: "godmode",
    layout: "Scatter",
    input: Perfect(AlwaysPerfect),
    max_frames: 4000,
    disallowed_failures: [BoltInBounds, BreakerCountReasonable, BreakerInBounds, NoNaN],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 3377,
    initial_effects: [
        On(target: Bolt, then: [
            When(trigger: Impacted(Cell), then: [
                Do(RampingDamage(damage_per_trigger: 0.25)),
            ]),
        ]),
    ],
)
