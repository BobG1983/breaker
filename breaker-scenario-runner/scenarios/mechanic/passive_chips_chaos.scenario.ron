// Adversarial: passive chip effects (Piercing, DamageBoost, SpeedBoost, SizeBoost) loaded via
// initial_effects. Dense layout maximises cell hits. Godmode breaker guarantees infinite play;
// Perfect(AlwaysPerfect) input drives reliable bump sequences to trigger repeated effect
// application. If any passive effect handler corrupts bolt state (speed, position, NaN) under
// sustained load this scenario will catch it.
(
    breaker: "godmode",
    layout: "Dense",
    input: Perfect(AlwaysPerfect),
    max_frames: 5000,
    disallowed_failures: [BoltInBounds, BoltSpeedAccurate, BreakerCountReasonable, BreakerInBounds, BreakerPositionClamped, NoEntityLeaks, NoNaN],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    seed: 7331,
    initial_effects: [
        On(target: Bolt, then: [
            When(trigger: Bumped, then: [
                Do(Piercing(1)),
                Do(DamageBoost(0.5)),
                Do(SpeedBoost(multiplier: 1.2)),
                Do(SizeBoost(0.2)),
            ]),
        ]),
    ],
)
