// Adversarial: Shield fires at NodeStart with 2 charges on all cells. Simultaneously,
// Shockwave fires on every cell impact — the expanding ring destroys cells in bursts,
// generating rapid CellDestroyed events and bolt-loss candidates. The shield absorbs up
// to 2 bolt-loss events; after that, normal bolt-loss resumes. The stress point is the
// charge decrement path: if ShieldActive is not removed when charges reach zero the
// ShieldChargesConsistent invariant fires (charges == 0 is illegal — the component must
// be removed). Shockwave also spawns ring entities that must despawn; NoEntityLeaks catches
// any Shockwave ring or expired Shield component accumulation. BoltInBounds ensures that
// a shielded bolt-loss (bolt resurrected by shield) does not leave the bolt outside the
// playfield. Dense layout with action_prob: 0.7 maximises simultaneous hits and rapid
// charge exhaustion. 8000 frames is long enough to exhaust charges and verify clean teardown.
// Stress: 16 runs at varied seeds to cover different bolt-loss timing relative to shockwave
// burst windows.
(
    breaker: "Aegis",
    layout: "Dense",
    input: Chaos((action_prob: 0.7)),
    max_frames: 8000,
    disallowed_failures: [NoEntityLeaks, ShieldChargesConsistent, NoNaN, BoltInBounds],
    allowed_failures: None,
    debug_setup: None,
    allow_early_end: false,
    stress: (runs: 16, parallelism: 16),
    seed: 4447,
    initial_effects: [
        On(target: AllCells, then: [
            When(trigger: NodeStart, then: [
                Do(Shield(stacks: 2)),
            ]),
        ]),
        On(target: Bolt, then: [
            When(trigger: Impacted(Cell), then: [
                Do(Shockwave(base_range: 56.0, range_per_level: 0.0, stacks: 1, speed: 400.0)),
            ]),
        ]),
    ],
)
