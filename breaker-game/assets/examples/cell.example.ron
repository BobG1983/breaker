// Example CellTypeDefinition — documents all available fields.
//
// Required fields:
//   id, alias, hp, color_rgb, required_to_clear,
//   damage_hdr_base, damage_green_min, damage_blue_range, damage_blue_base
//
// Optional fields (all default to None/absent):
//   behaviors — list of CellBehavior variants
//   effects   — list of RootEffect chains (same format as bolt/wall effects)
//
// CellBehavior variants:
//   Regen(rate: f32)           — cell regenerates HP at `rate` per second
//   Guarded(GuardedBehavior)   — cell spawns guardian children in a 3x3 ring
//
// GuardedBehavior fields:
//   guardian_hp: f32            — hit points for each guardian cell
//   guardian_color_rgb: (r,g,b) — HDR color for guardian cells
//   slide_speed: f32            — guardian slide speed in world units/sec (0 = stationary)
//
// Alias conventions:
//   Single char: "S", "T", "R", "L" (standard, tough, regen, lock)
//   Multi-char:  "Gu" (guarded parent), "gu" (guardian child grid marker)
//   Reserved:    "." (empty grid position)

// --- Standard cell ---
// (
//     id: "standard",
//     alias: "S",
//     hp: 10.0,
//     color_rgb: (4.0, 0.2, 0.5),
//     required_to_clear: true,
//     damage_hdr_base: 4.0,
//     damage_green_min: 0.2,
//     damage_blue_range: 0.4,
//     damage_blue_base: 0.2,
// )

// --- Regen cell ---
// (
//     id: "regen",
//     alias: "R",
//     hp: 20.0,
//     color_rgb: (0.3, 4.0, 0.3),
//     required_to_clear: true,
//     damage_hdr_base: 4.0,
//     damage_green_min: 0.4,
//     damage_blue_range: 0.3,
//     damage_blue_base: 0.1,
//     behaviors: Some([Regen(rate: 2.0)]),
// )

// --- Guarded cell (parent) ---
// (
//     id: "guarded",
//     alias: "Gu",
//     hp: 30.0,
//     color_rgb: (0.8, 0.3, 4.0),
//     required_to_clear: true,
//     damage_hdr_base: 4.0,
//     damage_green_min: 0.2,
//     damage_blue_range: 0.4,
//     damage_blue_base: 0.2,
//     behaviors: Some([
//         Guarded((
//             guardian_hp: 15.0,
//             guardian_color_rgb: (0.5, 0.2, 3.0),
//             slide_speed: 60.0,
//         )),
//     ]),
// )

// --- Guardian cell (grid marker — not spawned independently) ---
// (
//     id: "guardian",
//     alias: "gu",
//     hp: 15.0,
//     color_rgb: (0.5, 0.2, 3.0),
//     required_to_clear: false,
//     damage_hdr_base: 3.0,
//     damage_green_min: 0.1,
//     damage_blue_range: 0.3,
//     damage_blue_base: 0.2,
// )
