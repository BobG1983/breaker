(
    name: "Circuit Breaker",
    description: "Three perfect bumps close the circuit — spawning a bolt and unleashing a massive shockwave",
    effects: [
        Stamp(Bolt,
            When(PerfectBumped,
                Fire(CircuitBreaker(CircuitBreakerConfig(
                    bumps_required: 3,
                    spawn_count: 1,
                    inherit: true,
                    shockwave_range: 160.0,
                    shockwave_speed: 500.0,
                ))),
            ),
        ),
    ],
    ingredients: [
        (chip_name: "Overclock", stacks_required: 1),
        (chip_name: "Bump Force", stacks_required: 2),
    ],
)
