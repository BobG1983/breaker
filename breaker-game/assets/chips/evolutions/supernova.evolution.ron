(
    name: "Supernova",
    description: "Perfect bumps trigger chain explosions — cells destroyed spawn bolts and shockwaves",
    effects: [
        Stamp(Bolt,
            When(PerfectBumped,
                When(Impacted(Cell),
                    When(Killed(Cell),
                        Sequence([
                            Fire(SpawnBolts(SpawnBoltsConfig(count: 2, lifespan: Some(3.0), inherit: true))),
                            Fire(Shockwave(ShockwaveConfig(base_range: 96.0, range_per_level: 0.0, stacks: 1, speed: 400.0))),
                        ]),
                    ),
                ),
            ),
        ),
    ],
    ingredients: [
        (chip_name: "Piercing Shot", stacks_required: 3),
        (chip_name: "Surge", stacks_required: 1),
    ],
)
