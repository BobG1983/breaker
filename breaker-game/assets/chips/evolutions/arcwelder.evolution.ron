(
    name: "Arcwelder",
    description: "All your bolts connected by crackling neon beams that damage everything they intersect",
    effects: [
        Stamp(Bolt,
            When(Bumped,
                Fire(TetherBeam(TetherBeamConfig(damage_mult: 1.5, chain: true, width: 10.0))),
            ),
        ),
    ],
    ingredients: [
        (chip_name: "Tether", stacks_required: 2),
        (chip_name: "Amp", stacks_required: 2),
    ],
)
