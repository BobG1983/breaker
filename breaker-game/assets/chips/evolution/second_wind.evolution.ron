(
    name: "Second Wind",
    description: "Losing a bolt grants temporary invulnerability — cheat death once",
    effects: [
        On(target: Breaker, then: [
            When(trigger: OnBoltLost, then: [
                Do(SecondWind(invuln_secs: 3.0)),
            ],
        ],
    ],
    ingredients: [
        (chip_name: "Wide Breaker", stacks_required: 3),
        (chip_name: "Breaker Speed", stacks_required: 3),
    ],
)
