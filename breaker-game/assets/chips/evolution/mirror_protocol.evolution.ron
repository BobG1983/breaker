(
    name: "Mirror Protocol",
    description: "Perfect bumps spawn mirrored piercing bolts that spread in controlled directions",
    effects: [
        On(target: Bolt, then: [
            When(trigger: PerfectBump, then: [
                Do(MirrorProtocol(inherit: true)),
            ]),
        ]),
    ],
    ingredients: [
        (chip_name: "Reflex", stacks_required: 1),
        (chip_name: "Piercing Shot", stacks_required: 2),
    ],
)
