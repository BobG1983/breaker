(
    name: "Railgun",
    description: "Perfect bumps fire a devastating piercing beam through all cells in the bolt's path",
    max_stacks: 1,
    effects: [
        On(target: Bolt, then: [
            When(trigger: PerfectBumped, then: [
                Do(PiercingBeam(damage_mult: 3.0, width: 30.0)),
            ]),
        ]),
    ],
    ingredients: Some([
        (chip_name: "Piercing Shot", stacks_required: 3),
        (chip_name: "Bolt Speed", stacks_required: 4),
    ]),
)
