(
    name: "Gravity Well",
    description: "Destroying cells creates gravity wells that pull bolts toward the destruction point",
    effects: [
        On(target: Bolt, then: [
            When(trigger: DestroyedCell, then: [
                Do(GravityWell(strength: 500.0, duration: 3.0, radius: 128.0, max: 2)),
            ],
        ],
    ],
    ingredients: [
        (chip_name: "Bolt Size", stacks_required: 2),
        (chip_name: "Magnetism", stacks_required: 2),
    ],
)
