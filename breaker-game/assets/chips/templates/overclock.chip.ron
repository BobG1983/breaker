        effects: [
            On(target: Bolt, then: [
                When(trigger: PerfectBumped, then: [
                    Until(trigger: TimeExpires(4.0), then: [
                        Do(SpeedBoost(multiplier: 1.3)),
                        Do(DamageBoost(1.25)),
                    ]),
                ]),
            ]),
        ],
    ),
    rare: (
        prefix: "Supercharged",
        effects: [
            On(target: Bolt, then: [
                When(trigger: PerfectBumped, then: [
                    Until(trigger: TimeExpires(5.0), then: [
                        Do(SpeedBoost(multiplier: 1.4)),
                        Do(DamageBoost(1.4)),
                    ]),
                ]),
            ]),
        ],
    ),
