(
    name: "Chain Reaction",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            On(target: Bolt, then: [
                When(trigger: DestroyedCell, then: [
                    When(trigger: DestroyedCell, then: [
                        Do(SpawnBolts()),
                    ]),
                ]),
            ]),
        ],
    ),
)
