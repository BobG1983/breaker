(
    name: "Reflex",
    max_taken: 1,
    uncommon: (
        prefix: "Quick",
        effects: [
            On(target: Breaker, then: [
                When(trigger: PerfectBump, then: [
                    Do(SpawnBolts()),
                ]),
            ]),
        ],
    ),
    rare: (
        prefix: "Lightning",
        effects: [
            On(target: Breaker, then: [
                When(trigger: PerfectBump, then: [
                    Do(SpawnBolts()),
                    Do(SpeedBoost(multiplier: 1.2)),
                ]),
            ]),
        ],
    ),
)
