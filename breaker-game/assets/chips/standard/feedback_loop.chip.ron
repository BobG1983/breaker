(
    name: "Feedback Loop",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            On(target: Bolt, then: [
                When(trigger: PerfectBumped, then: [
                    When(trigger: Impacted(Cell), then: [
                        When(trigger: CellDestroyed, then: [
                            Until(trigger: TimeExpires(3.0), then: [
                                Do(SpeedBoost(multiplier: 1.5)),
                            ]),
                        ]),
                    ]),
                ]),
            ]),
        ],
    ),
)
