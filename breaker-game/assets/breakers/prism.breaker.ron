/* @[brickbreaker::effect::definition::BreakerDefinition] */
(
    name: "Prism",
    stat_overrides: (),
    life_pool: None,
    effects: [
        On(target: Breaker, then: [When(trigger: OnBoltLost, then: [Do(TimePenalty(seconds: 7.0))])]),
        On(target: Breaker, then: [When(trigger: PerfectBump, then: [Do(SpawnBolts())])]),
    ],
)
