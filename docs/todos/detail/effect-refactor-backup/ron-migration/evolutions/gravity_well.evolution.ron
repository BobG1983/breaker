// MIGRATED: new effect system syntax
// Gravity Well: killing cells creates gravity wells
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// CellDestroyed on bolt → Killed(Cell): "I killed a cell" (local, fires on killer)
(
    name: "Gravity Well",
    description: "Destroying cells creates gravity wells that pull bolts toward the destruction point",
    effects: [
        Route(Bolt, When(Killed(Cell), Fire(GravityWell(strength: 500.0, duration: 5.0, radius: 160.0, max: 4)))),
    ],
    ingredients: [
        (chip_name: "Bolt Size", stacks_required: 2),
        (chip_name: "Magnetism", stacks_required: 2),
    ],
)
