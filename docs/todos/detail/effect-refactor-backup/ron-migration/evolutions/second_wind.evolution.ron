// MIGRATED: new effect system syntax
// Second Wind: losing a bolt grants temporary invulnerability
// Route(Breaker, ...) → effect stamped on breaker, This = breaker
// BoltLost on breaker → BoltLostOccurred (global trigger)
(
    name: "Second Wind",
    description: "Losing a bolt grants temporary invulnerability — cheat death once",
    effects: [
        Route(Breaker, When(BoltLostOccurred, Fire(SecondWind))),
    ],
    ingredients: [
        (chip_name: "Wide Breaker", stacks_required: 2),
        (chip_name: "Last Stand", stacks_required: 1),
    ],
)
