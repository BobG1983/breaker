// MIGRATED: new effect system syntax
// Death Lightning: when bolt hits a cell, stamp "when you die, chain lightning" on that cell
// This is the Transfer pattern:
//   On(Bolt) → When(Impacted(Cell)) → On(Cell) → When(Died) → Do(ChainLightning)
// becomes:
//   Route(Bolt, When(Impacted(Cell)) → On(ImpactTarget::Impactee) → Transfer(When(Died) → Fire(ChainLightning)))
// After transfer, the cell owns the effect. This = the cell. Died fires on victim (the cell).
(
    name: "Death Lightning",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            Route(Bolt, When(Impacted(Cell), On(ImpactTarget::Impactee, Transfer(
                When(Died, Fire(ChainLightning(arcs: 3, range: 64.0, damage_mult: 1.0)))
            )))),
        ],
    ),
)
