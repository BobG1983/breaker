// MIGRATED: new effect system syntax
// Augment: breaker size + bump force + speed boost (passive)
// Route(Breaker, ...) → immediate passive on breaker
// This = breaker
(
    name: "Augment",
    max_taken: 2,
    common: (
        prefix: "Basic",
        effects: [
            Route(Breaker, Fire(SizeBoost(1.15))),
            Route(Breaker, Fire(BumpForce(1.15))),
        ],
    ),
    uncommon: (
        prefix: "Sturdy",
        effects: [
            Route(Breaker, Fire(SizeBoost(1.25))),
            Route(Breaker, Fire(BumpForce(1.25))),
        ],
    ),
    rare: (
        prefix: "Fortified",
        effects: [
            Route(Breaker, Fire(SizeBoost(1.4))),
            Route(Breaker, Fire(BumpForce(1.35))),
            Route(Breaker, Fire(SpeedBoost(multiplier: 1.15))),
        ],
    ),
)
