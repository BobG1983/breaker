// MIGRATED: new effect system syntax
// Magnetism: bolt attracts toward cells (passive)
// Route(Bolt, ...) → stamped on bolt, This = bolt
(
    name: "Magnetism",
    max_taken: 3,
    common: (
        prefix: "Faint",
        effects: [
            Route(Bolt, Fire(Attraction(attraction_type: Cell, force: 0.5, max_force: Some(50.0)))),
        ],
    ),
    uncommon: (
        prefix: "Steady",
        effects: [
            Route(Bolt, Fire(Attraction(attraction_type: Cell, force: 1.0, max_force: Some(80.0)))),
        ],
    ),
    rare: (
        prefix: "Powerful",
        effects: [
            Route(Bolt, Fire(Attraction(attraction_type: Cell, force: 1.5, max_force: Some(120.0)))),
            Route(Bolt, Fire(SizeBoost(1.1))),
        ],
    ),
)
