// MIGRATED: new effect system syntax
// Ricochet Protocol: bolt gets damage boost after wall impact, until next wall impact
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// Impacted(Wall) is local: fires on both entities. Bolt is Impactor, Wall is Target.
// Until reverses the DamageBoost when the bolt hits another wall.
(
    name: "Ricochet Protocol",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            Route(Bolt, When(Impacted(Wall), Until(Impacted(Wall), Fire(DamageBoost(3.0))))),
        ],
    ),
)
