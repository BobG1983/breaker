// MIGRATED: new effect system syntax
// Cascade: shockwave from bolt when bolt kills a cell
// Route(Bolt, ...) → bolt-centric "I killed a cell"
// CellDestroyed → Killed(Cell) because this is on a bolt (the killer)
// Shockwave fires from the bolt (This).
(
    name: "Cascade",
    max_taken: 3,
    common: (
        prefix: "Minor",
        effects: [
            Route(Bolt, When(Killed(Cell), Fire(Shockwave(base_range: 20.0, range_per_level: 5.0, stacks: 1, speed: 400.0)))),
        ],
    ),
    uncommon: (
        prefix: "Spreading",
        effects: [
            Route(Bolt, When(Killed(Cell), Fire(Shockwave(base_range: 30.0, range_per_level: 8.0, stacks: 1, speed: 400.0)))),
        ],
    ),
    rare: (
        prefix: "Devastating",
        effects: [
            Route(Bolt, When(Killed(Cell), Fire(Shockwave(base_range: 40.0, range_per_level: 12.0, stacks: 1, speed: 400.0)))),
        ],
    ),
)
