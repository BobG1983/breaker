// MIGRATED: new effect system syntax
// Gauntlet: bolt gets size + speed + damage boost (passive, no trigger)
// Route(Bolt, ...) → stamped on bolt, This = bolt
(
    name: "Gauntlet",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            Route(Bolt, Fire(SizeBoost(1.5))),
            Route(Bolt, Fire(SpeedBoost(multiplier: 1.4))),
            Route(Bolt, Fire(DamageBoost(0.5))),
        ],
    ),
)
