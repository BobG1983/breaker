// MIGRATED: new effect system syntax
// Tether: bolt chains to nearby cell on cell impact after perfect bump
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// PerfectBumped is local (fires on both bolt and breaker), bolt is participant
// Impacted(Cell) is local: fires on both entities. Bolt is Impactor, Cell is Target.
// ChainBolt fires from the bolt (This).
// Nested When(PerfectBumped) → When(Impacted(Cell)) preserved as nested trigger gates.
(
    name: "Tether",
    max_taken: 2,
    common: (
        prefix: "Short",
        effects: [
            Route(Bolt, When(PerfectBumped, When(Impacted(Cell), Fire(ChainBolt(tether_distance: 80.0))))),
        ],
    ),
    uncommon: (
        prefix: "Extended",
        effects: [
            Route(Bolt, When(PerfectBumped, When(Impacted(Cell), Fire(ChainBolt(tether_distance: 120.0))))),
        ],
    ),
    rare: (
        prefix: "Long",
        effects: [
            Route(Bolt, When(PerfectBumped, When(Impacted(Cell), Fire(ChainBolt(tether_distance: 160.0))))),
        ],
    ),
)
