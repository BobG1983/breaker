// MIGRATED: new effect system syntax
// Damage Boost: bolt deals more damage (passive)
// Route(Bolt, ...) → immediate passive on bolt
// This = bolt
(
    name: "Damage Boost",
    max_taken: 5,
    common: (
        prefix: "Minor",
        effects: [
            Route(Bolt, Fire(DamageBoost(1.1))),
        ],
    ),
    uncommon: (
        prefix: "Potent",
        effects: [
            Route(Bolt, Fire(DamageBoost(1.2))),
        ],
    ),
    rare: (
        prefix: "Savage",
        effects: [
            Route(Bolt, Fire(DamageBoost(1.35))),
        ],
    ),
)
