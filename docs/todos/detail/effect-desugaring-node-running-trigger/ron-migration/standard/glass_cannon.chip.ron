// MIGRATED: new effect system syntax
// Glass Cannon: bolt deals massive damage, but breaker loses a life on bolt loss
// Mixed targets: Route(Bolt, ...) for bolt effect, Route(Breaker, ...) for breaker effect.
// BoltLost → BoltLostOccurred (global trigger)
(
    name: "Glass Cannon",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            Route(Bolt, Fire(DamageBoost(3.0))),
            Route(Breaker, When(BoltLostOccurred, Fire(LoseLife))),
        ],
    ),
)
