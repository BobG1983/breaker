// MIGRATED: new effect system syntax
// Pulse: bolt emits pulse waves on bump
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// PerfectBumped is local (fires on both bolt and breaker), bolt is participant
// Bumped is local (any successful bump grade), bolt is participant
(
    name: "Pulse",
    max_taken: 3,
    common: (
        prefix: "Faint",
        effects: [
            Route(Bolt, When(PerfectBumped, Fire(Pulse(base_range: 16.0, range_per_level: 4.0, stacks: 1, speed: 600.0, interval: 0.5)))),
        ],
    ),
    uncommon: (
        prefix: "Resonant",
        effects: [
            Route(Bolt, When(Bumped, Fire(Pulse(base_range: 20.0, range_per_level: 5.0, stacks: 1, speed: 600.0, interval: 0.4)))),
        ],
    ),
    rare: (
        prefix: "Harmonic",
        effects: [
            Route(Bolt, When(Bumped, Fire(Pulse(base_range: 24.0, range_per_level: 6.0, stacks: 2, speed: 700.0, interval: 0.3)))),
        ],
    ),
)
