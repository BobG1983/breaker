// MIGRATED: new effect system syntax
// Parry: breaker gets shield on perfect bump, all bolts shockwave on perfect bump
// Mixed targets: Route(Breaker, ...) for shield, Route(ActiveBolts, ...) for shockwave.
// PerfectBump → PerfectBumpOccurred (global trigger)
// AllBolts → ActiveBolts (point-in-time snapshot, correct for triggered effect)
(
    name: "Parry",
    max_taken: 1,
    legendary: (
        prefix: "",
        effects: [
            Route(Breaker, When(PerfectBumpOccurred, Fire(Shield(duration: 3.0, reflection_cost: 0.5)))),
            Route(ActiveBolts, When(PerfectBumpOccurred, Fire(Shockwave(base_range: 64.0, range_per_level: 0.0, stacks: 1, speed: 500.0)))),
        ],
    ),
)
