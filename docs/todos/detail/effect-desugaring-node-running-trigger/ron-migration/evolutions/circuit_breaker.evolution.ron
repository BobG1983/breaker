// MIGRATED: new effect system syntax
// Circuit Breaker: three perfect bumps trigger spawn + shockwave
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// PerfectBumped is local: fires on both bolt and breaker. Bolt is This.
(
    name: "Circuit Breaker",
    description: "Three perfect bumps close the circuit — spawning a bolt and unleashing a massive shockwave",
    effects: [
        Route(Bolt, When(PerfectBumped, Fire(CircuitBreaker(
            bumps_required: 3,
            spawn_count: 1,
            inherit: true,
            shockwave_range: 160.0,
            shockwave_speed: 500.0,
        )))),
    ],
    ingredients: [
        (chip_name: "Feedback Loop", stacks_required: 1),
        (chip_name: "Bump Force", stacks_required: 2),
    ],
)
