// Route(Breaker, ...) → effect stamped on breaker, This = breaker
(
    name: "FlashStep",
    description: "Reverse-dash while settling to teleport — skip the slowdown, flash to position",
    effects: [
        Route(Breaker, Fire(FlashStep)),
    ],
    ingredients: [
        (chip_name: "Breaker Speed", stacks_required: 2),
        (chip_name: "Reflex", stacks_required: 1),
    ],
)
