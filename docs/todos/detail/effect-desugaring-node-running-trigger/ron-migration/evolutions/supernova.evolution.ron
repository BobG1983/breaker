// MIGRATED: new effect system syntax
// Supernova: perfect bump → cell impact → cell kill → spawn bolts + shockwave
// Route(Bolt, ...) → effect stamped on bolt, This = bolt
// PerfectBumped is local: fires on both bolt and breaker. Bolt is This.
// Impacted(Cell) is local: fires on both entities. Bolt is Impactor, Cell is Target.
// CellDestroyed on bolt → Killed(Cell): "I killed a cell" (local, fires on killer)
// Triple-nested When chain. Two effects from same innermost trigger require two entries.
(
    name: "Supernova",
    description: "Perfect bumps trigger chain explosions — cells destroyed spawn bolts and shockwaves",
    effects: [
        Route(Bolt, When(PerfectBumped, When(Impacted(Cell), When(Killed(Cell), Fire(SpawnBolts(count: 2, inherit: true)))))),
        Route(Bolt, When(PerfectBumped, When(Impacted(Cell), When(Killed(Cell), Fire(Shockwave(base_range: 96.0, range_per_level: 0.0, stacks: 1, speed: 400.0)))))),
    ],
    ingredients: [
        (chip_name: "Piercing Shot", stacks_required: 3),
        (chip_name: "Surge", stacks_required: 1),
    ],
)
