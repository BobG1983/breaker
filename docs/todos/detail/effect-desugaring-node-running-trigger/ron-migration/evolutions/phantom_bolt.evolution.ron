// MIGRATED: new effect system syntax
// Phantom Bolt: successful bumps summon a spectral phantom bolt
// Route(Breaker, ...) → effect stamped on breaker, This = breaker
// Bump (no -ed suffix) was the global trigger → BumpOccurred
(
    name: "Phantom Bolt",
    description: "Successful bumps summon a spectral phantom bolt",
    effects: [
        Route(Breaker, When(BumpOccurred, Fire(SpawnPhantom(duration: 5.0, max_active: 5)))),
    ],
    ingredients: [
        (chip_name: "Wide Breaker", stacks_required: 2),
        (chip_name: "Bump Force", stacks_required: 2),
    ],
)
