#!/bin/sh
# Pre-commit hook: format, lint, and test

# Snapshot the list of staged .rs files BEFORE cargo fmt so we only re-add
# files the user already included in this commit — not arbitrary unstaged
# edits that happen to be in the working tree.
STAGED_RS=$(git diff --name-only --cached --diff-filter=ACMR | grep '\.rs$')

# Format the whole workspace (cargo fmt has no "format only these files" mode
# without risking inconsistent style across the workspace).
cargo fmt

# Re-stage only the .rs files that were already part of this commit.
if [ -n "$STAGED_RS" ]; then
    echo "$STAGED_RS" | xargs -r git add
fi

# Clippy — workspace lints in Cargo.toml enforce deny on all warnings
echo "Running workspace clippy..."
cargo all-dclippy
if [ $? -ne 0 ]; then
    echo "❌ Clippy failed. Fix warnings before committing."
    exit 1
fi

# Tests — reject commit on any failures
echo "Running workspace tests..."
cargo all-dtest
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Fix failures before committing."
    exit 1
fi
