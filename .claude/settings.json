{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "WebSearch",
      "WebFetch",
      "Bash(cargo dev:*)",
      "Bash(cargo dbuild:*)",
      "Bash(cargo dcheck:*)",
      "Bash(cargo dclippy:*)",
      "Bash(cargo dtest:*)",
      "Bash(cargo dscenario:*)",
      "Bash(cargo scenario:*)",
      "Bash(cargo dstest:*)",
      "Bash(cargo dsclippy:*)",
      "Bash(cargo dscheck:*)",
      "Bash(cargo all-dtest:*)",
      "Bash(cargo all-dclippy:*)",
      "Bash(cargo spatial2dtest:*)",
      "Bash(cargo spatial2dclippy:*)",
      "Bash(cargo spatial2dcheck:*)",
      "Bash(cargo physics2dtest:*)",
      "Bash(cargo physics2dclippy:*)",
      "Bash(cargo defaultstest:*)",
      "Bash(cargo defaultsclippy:*)",
      "Bash(cargo stateflowtest:*)",
      "Bash(cargo stateflowclippy:*)",
      "Bash(cargo stateflowcheck:*)",
      "Bash(cargo run:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo metadata:*)",
      "Bash(time cargo:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git flow:*)",
      "Bash(git tag:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git push:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(wc:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Read(//tmp/**)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:bevyengine.org)",
      "WebFetch(domain:github.com)",
      "mcp__graphify__get_community",
      "mcp__graphify__get_neighbors",
      "mcp__graphify__get_node",
      "mcp__graphify__god_nodes",
      "mcp__graphify__graph_stats",
      "mcp__graphify__query_graph",
      "mcp__graphify__shortest_path"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}